generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  excerpt        String   @default("")
  content        String   @default("")
  category       String   @default("Articles")
  author         String   @default("Anonymous")
  date           String   @default("")
  imageUrl       String   @default("")
  readingTime    String   @default("5 min read")
  status         String   @default("Draft")
  tags           String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  authorBio      String   @default("")
  authorImage    String   @default("")
  showOnHomepage Boolean  @default(true)

  @@index([slug])
}

model Voice {
  id          String   @id @default(cuid())
  contributor String
  role        String   @default("")
  quote       String   @default("")
  imageUrl    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TagStore {
  id        String   @id @default(cuid())
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default(cuid())
  siteName        String   @default("THE INKSPIRE")
  description     String   @default("A Digital Magazine exploring faith, art, and history.")
  contactEmail    String   @default("editor@theinkspire.com")
  socialTwitter   String   @default("")
  socialInstagram String   @default("")
  primaryColor    String   @default("#2E5BFF")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model HeroConfig {
  id               String   @id @default(cuid())
  articleSlug      String   @default("architecture-of-silence")
  customTitle      String   @default("")
  customExcerpt    String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  featuredSlugs    String[] @default([])
  fictionSlugs     String[] @default([])
  perspectiveSlugs String[] @default([])
  articleSlugs     String[] @default([])
  mythosSlugs      String[] @default([])
  secondarySlugs   String[] @default([])
}

model Comment {
  id        String   @id @default(cuid())
  author    String   @default("Anonymous")
  content   String
  article   String   @default("")
  date      String   @default("")
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  url       String
  name      String
  size      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  publicId  String?
}
